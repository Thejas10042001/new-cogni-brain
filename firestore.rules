
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/cognitive_documents
    // Fields:
    //   - id: string (required)
    //   - name: string (required, max 255)
    //   - content: string (required, max 1MB)
    //   - timestamp: number (required)
    //   - updatedAt: number (optional)
    //   - type: string (required)
    //   - folderId: string (optional)
    //
    // Collection: /users/{userId}/folders
    // Fields:
    //   - id: string (required)
    //   - name: string (required, max 100)
    //   - userId: string (required, must match parent)
    //   - isCustom: bool (required)
    //   - timestamp: number (required)
    //   - type: string (optional, enum: ['main', 'sub'])
    //   - parentId: string (optional)
    //
    // Collection: /users/{userId}/meeting_contexts
    // Fields:
    //   - sellerCompany: string (required)
    //   - clientCompany: string (required)
    //   - persona: string (required)
    //   - thinkingLevel: string (required)
    //   - temperature: number (required)
    //   [Other optional fields]
    //
    // Collection: /users/{userId}/simulation_history
    // Fields:
    //   - id: string (required)
    //   - userId: string (required, must match parent)
    //   - type: string (required, enum: ['avatar', 'avatar2', 'staged'])
    //   - timestamp: number (required)
    //   - meetingContext: map (required)
    //   - messages: list (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "thejasssreenivasu@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidDocument(data) {
      return hasRequiredFields(['id', 'name', 'content', 'timestamp', 'type']) &&
             data.name is string && data.name.size() <= 255 &&
             data.content is string && data.content.size() <= 1048576 &&
             data.timestamp is number &&
             data.type is string;
    }

    function isValidFolder(data, userId) {
      return hasRequiredFields(['id', 'name', 'userId', 'isCustom', 'timestamp']) &&
             data.name is string && data.name.size() <= 100 &&
             data.userId == userId &&
             data.isCustom is bool &&
             data.timestamp is number &&
             (!('type' in data) || data.type in ['main', 'sub']);
    }

    function isValidMeetingContext(data) {
      return hasRequiredFields(['sellerCompany', 'clientCompany', 'persona', 'thinkingLevel', 'temperature']) &&
             data.sellerCompany is string &&
             data.clientCompany is string &&
             data.persona is string &&
             data.thinkingLevel is string &&
             data.temperature is number;
    }

    function isValidSimulationHistory(data, userId) {
      return hasRequiredFields(['id', 'userId', 'type', 'timestamp', 'meetingContext', 'messages']) &&
             data.userId == userId &&
             data.type in ['avatar', 'avatar2', 'staged'] &&
             data.timestamp is number &&
             data.meetingContext is map &&
             data.messages is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /cognitive_documents/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidDocument(request.resource.data);
        allow update: if isOwner(userId) && isValidDocument(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /folders/{folderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidFolder(request.resource.data, userId);
        allow update: if isOwner(userId) && isValidFolder(request.resource.data, userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /meeting_contexts/{contextId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidMeetingContext(request.resource.data);
        allow update: if isOwner(userId) && isValidMeetingContext(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /simulation_history/{historyId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidSimulationHistory(request.resource.data, userId);
        allow update: if isOwner(userId) && isValidSimulationHistory(request.resource.data, userId);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
